# Production-only environment for `vite build` (NODE_ENV=production).
# Vite injects this into the bundle as `import.meta.env.VITE_API_URL` so the
# frontend talks to the live worker instead of falling back to same-origin.
#
# If the worker URL ever changes (custom domain, redeploy under a different
# Cloudflare account, etc.), update this file and rebuild.
VITE_API_URL=https://chatbridge-marketplace.felipe-perez.workers.dev
